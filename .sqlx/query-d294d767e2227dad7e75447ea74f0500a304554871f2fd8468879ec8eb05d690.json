  "query": "SELECT r.id, r.ctftime_team_id, r.ctf_event_id, r.place, r.score, r.total_teams,\n                      r.notified_at, r.created_at,\n                      array_agg(t.guild_id) as guild_ids\n               FROM team_results r\n               JOIN tracked_teams t ON t.ctftime_team_id = r.ctftime_team_id\n               WHERE r.notified_at IS NULL\n               GROUP BY r.id",
