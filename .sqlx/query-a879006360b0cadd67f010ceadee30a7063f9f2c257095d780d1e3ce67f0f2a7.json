{
  "db_name": "PostgreSQL",
  "query": "\n                    SELECT \n                        id, ctftime_id, title, url, summary, event_id, \n                        category, event_name, published_at, created_at as \"created_at!\",\n                        enriched_at, notified_at\n                    FROM writeups\n                    WHERE category = $1\n                    ORDER BY published_at DESC NULLS LAST, created_at DESC\n                    LIMIT $2\n                    OFFSET $3\n                    ",
