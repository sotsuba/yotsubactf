{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT \n                id, ctftime_id, title, url, event_id, \n                category, event_name, published_at, created_at as \"created_at!\"\n            FROM writeups\n            WHERE event_name ILIKE $1 OR title ILIKE $1\n            ORDER BY published_at DESC NULLS LAST, created_at DESC\n            LIMIT $2\n            OFFSET $3\n            ",
