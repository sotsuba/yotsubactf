{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 2,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Pending Reminders",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "scheduler_reminders_pending_count" }
      ]
    },
    {
      "title": "Reminders Fired/Skipped",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(scheduler_reminders_fired_total[5m])) by (result)",
          "legendFormat": "Fired ({{result}})"
        },
        {
          "expr": "sum(rate(scheduler_reminders_skipped_total[5m]))",
          "legendFormat": "Skipped"
        }
      ]
    },
    {
      "title": "Task Execution Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(scheduler_task_duration_seconds_bucket[5m])) by (le, task))",
          "legendFormat": "{{task}}"
        }
      ]
    },
    {
      "title": "Task Success/Failure Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(scheduler_tasks_total[5m])) by (task, result)",
          "legendFormat": "{{task}} ({{result}})"
        }
      ]
    },
    {
      "title": "Host CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU Usage (%)"
        }
      ]
    },
    {
      "title": "Host Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "Memory Usage (%)"
        }
      ]
    },
    {
      "title": "Host Disk Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "100 * (1 - (node_filesystem_avail_bytes{mountpoint=\"/rootfs\"} / node_filesystem_size_bytes{mountpoint=\"/rootfs\"}))",
          "legendFormat": "Disk Usage (%)"
        }
      ]
    },
    {
      "title": "Redis Memory Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "(redis_memory_used_bytes / redis_memory_max_bytes) * 100",
          "legendFormat": "Used Memory (%)"
        }
      ]
    },
    {
      "title": "Redis Eviction Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 24 },
      "targets": [
        {
          "expr": "rate(redis_evicted_keys_total[5m])",
          "legendFormat": "Evictions/s"
        }
      ]
    },
    {
      "title": "Redis Keyspace Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum(redis_db_keys) by (db)",
          "legendFormat": "DB {{db}}"
        }
      ]
    },
    {
      "title": "Redis Connected Clients",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Clients"
        }
      ]
    },
    {
      "title": "Postgres Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count) by (datname)",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "title": "Postgres Max Transaction Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 32 },
      "targets": [
        {
          "expr": "pg_stat_activity_max_tx_duration",
          "legendFormat": "Max TX Duration (s)"
        }
      ]
    },
    {
      "title": "Postgres Index Hit Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 32 },
      "targets": [
        {
          "expr": "sum(pg_statio_user_indexes_idx_blks_hit) / (sum(pg_statio_user_indexes_idx_blks_hit) + sum(pg_statio_user_indexes_idx_blks_read))",
          "legendFormat": "Index Hit Rate"
        }
      ]
    }



  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": [],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "CTFBot Scheduler",
  "uid": "ctfbot-scheduler",
  "version": 1,
  "weekStart": ""
}
