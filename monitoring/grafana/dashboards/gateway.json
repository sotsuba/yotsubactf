{
  "title": "CTFBot Gateway",
  "uid": "ctfbot-gateway",
  "refresh": "15s",
  "time": { "from": "now-3h", "to": "now" },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 100,
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Commands (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [{
        "expr": "sum(increase(gateway_commands_total[1h]))",
        "legendFormat": ""
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Success Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [{
        "expr": "sum(rate(gateway_commands_total{success=\"true\"}[5m])) / sum(rate(gateway_commands_total[5m]))",
        "legendFormat": ""
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0    },
              { "color": "yellow", "value": 0.90 },
              { "color": "green",  "value": 0.98 }
            ]
          }
        }
      }
    },
    {
      "title": "Guilds (subscribed)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [{
        "expr": "bot_guilds_total",
        "legendFormat": ""
      }]
    },
    {
      "title": "Rate Limited (5m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [{
        "expr": "sum(increase(gateway_rate_limit_total[5m]))",
        "legendFormat": ""
      }]
    },
    {
      "title": "Redis Miss Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [{
        "expr": "sum(rate(db_redis_misses_total[5m])) / (sum(rate(db_redis_hits_total[5m])) + sum(rate(db_redis_misses_total[5m])))",
        "legendFormat": ""
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0    },
              { "color": "yellow", "value": 0.3  },
              { "color": "red",    "value": 0.7  }
            ]
          }
        }
      }
    },
    {
      "title": "Slash vs Component",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [{
        "expr": "sum(rate(gateway_commands_total[5m])) by (kind)",
        "legendFormat": "{{kind}}"
      }]
    },
    {
      "id": 101,
      "title": "Commands",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Command Rate (per second)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [{
        "expr": "sum(rate(gateway_commands_total[5m])) by (command)",
        "legendFormat": "{{command}}"
      }]
    },
    {
      "title": "Top Commands (24h)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [{
        "expr": "sort_desc(sum(increase(gateway_commands_total[24h])) by (command))",
        "legendFormat": "{{command}}"
      }]
    },
    {
      "title": "Failed Commands",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [{
        "expr": "sum(rate(gateway_commands_total{success=\"false\"}[5m])) by (command)",
        "legendFormat": "{{command}}"
      }]
    },
    {
      "id": 102,
      "title": "Latency & errors",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Average Latency by Command",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "targets": [{
        "expr": "rate(gateway_command_latency_seconds_sum[5m]) / rate(gateway_command_latency_seconds_count[5m])",
        "legendFormat": "avg {{command}}"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Latency p50 / p99 (Under Construction)",
      "type": "text",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "options": {
        "content": "<div style=\"text-align: center; padding: 40px;\">\n  <h3>🚧 Under Construction 🚧</h3>\n  <p>Histogram buckets are currently not emitting correctly. Debugging in progress.</p>\n</div>",
        "mode": "html"
      }
    },
    {
      "id": 103,
      "title": "CTFTime API",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "CTFTime API — Success vs Error",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum(rate(ctftime_api_requests_total{status=\"200\"}[5m])) by (endpoint)",
          "legendFormat": "✓ {{endpoint}}"
        },
        {
          "expr": "sum(rate(ctftime_api_requests_total{status=~\"[45]..|error\"}[5m])) by (endpoint, status)",
          "legendFormat": "✗ {{endpoint}} {{status}}"
        }
      ]
    },
    {
      "title": "CTFTime API Latency p90",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [{
        "expr": "histogram_quantile(0.9, sum(rate(ctftime_api_latency_seconds_bucket[5m])) by (le, endpoint))",
        "legendFormat": "p90 {{endpoint}}"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}