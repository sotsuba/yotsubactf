# ── Required ──────────────────────────────────────────────────────────────────

# Discord Bot Token
DISCORD_TOKEN=

# Discord Application ID (found in Discord Developer Portal)
DISCORD_APPLICATION_ID=

# Postgres connection string
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://ctfbot:ctfbot@localhost:5432/ctfbot

# ── Optional ──────────────────────────────────────────────────────────────────

# Discord Guild ID (optional, for guild-scoped command registration)
DISCORD_GUILD_ID=

# Redis URL (optional, used for caching)
# REDIS_URL=redis://localhost:6379

# Bot contact email (sent in User-Agent to CTFtime)
BOT_CONTACT_EMAIL=admin@example.com

# Grafana admin password
GRAFANA_PASSWORD=admin

# Alertmanager
# required: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=
# required: https://hc-ping.com/your-uuid from Healthchecks.io
HEALTHCHECKS_PING_URL=

# ── Scheduler Intervals (optional, in seconds) ────────────────────────────────

# SCRAPE_INTERVAL_SECS=3600
# RESULTS_INTERVAL_SECS=21600
# WRITEUPS_INTERVAL_SECS=7200
# DIGEST_INTERVAL_SECS=3600
# REMIND_INTERVAL_SECS=60