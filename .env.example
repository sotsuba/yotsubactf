# ── Required ──────────────────────────────────────────────────────────────────

# Discord Bot Token
DISCORD_TOKEN=

# Discord Application ID (found in Discord Developer Portal)
DISCORD_APPLICATION_ID=

# Postgres connection string
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://ctfbot:ctfbot@localhost:5432/ctfbot

# ── Optional ──────────────────────────────────────────────────────────────────

# Discord Guild ID (optional, for guild-scoped command registration)
DISCORD_GUILD_ID=

# Redis URL (optional, used for caching)
# REDIS_URL=redis://localhost:6379

# Bot contact email (sent in User-Agent to CTFtime)
BOT_CONTACT_EMAIL=admin@example.com

# Gemini API key (LLM enrichment)
GEMINI_ENABLED=false
GEMINI_API_KEY=
# Optional: override Gemini model
# GEMINI_MODEL=gemini-2.0-flash
# Optional: LLM timeouts (seconds)
# GEMINI_TIMEOUT_SECS=20
# GEMINI_DIGEST_TIMEOUT_SECS=6
# Optional: throttle for category + event description (milliseconds)
# GEMINI_GATED_MIN_INTERVAL_MS=5000
# GEMINI_GATED_MAX_INTERVAL_MS=20000

# Grafana admin password
GRAFANA_PASSWORD=admin

# Alertmanager
# required: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=
# required: https://hc-ping.com/your-uuid from Healthchecks.io
HEALTHCHECKS_PING_URL=

# ── Scheduler Intervals (optional, in seconds) ────────────────────────────────

# SCRAPE_INTERVAL_SECS=3600
# RESULTS_INTERVAL_SECS=21600
# WRITEUPS_INTERVAL_SECS=7200
# DIGEST_INTERVAL_SECS=3600
# REMIND_INTERVAL_SECS=60

# ── Backup Settings (S3-compatible) ───────────────────────────────────────────

BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=