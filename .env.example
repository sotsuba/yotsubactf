# Discord
DISCORD_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_CHANNEL_ID=
# Staging guild for guild-scoped command registration
DISCORD_GUILD_ID=

# Sharding (optional). If DISCORD_SHARD_TOTAL is empty, use Discord recommended count.
# DISCORD_SHARD_START and DISCORD_SHARD_END are inclusive and 0-based.
DISCORD_SHARD_TOTAL=
DISCORD_SHARD_START=0
DISCORD_SHARD_END=0

# Database
DATABASE_URL=postgres://ctfbot:ctfbot@localhost:5432/ctfbot
REDIS_URL=redis://localhost:6379

# Scraper
SCRAPER_DELAY_MS=500

# Logging
RUST_LOG=info